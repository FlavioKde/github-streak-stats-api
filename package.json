{
    "name": "github-streak-stats-api",
    "version": "1.0.0",
    "description": "API for fetching GitHub streak stats",
    "type": "module",
    "engines": {
        "node": ">=18.x"
    },
    "scripts": {
    "dev": "vercel dev",
    "deploy": "vercel --prod",
    "start": "node api/streak/svg.js",
    "format": "prettier --write .",
    "clean": "rm -rf node_modules package-lock.json",
    "test": "vitest",
    "test:run": "vitest run",
    "test:watch": "vitest"
    },
    "dependencies": {
    "node-fetch": "^3.3.2"
    },
    "devDependencies": {
    "prettier": "^3.8.1",
    "vitest": "^4.0.18"
    },
    "keywords": [
    "github",
    "streak",
    "stats",
    "vercel",
    "serverless",
    "api",
    "fork"
    ],
    "author": "FlavioKde",
    "license": "MIT",    
    "repository": {
        "type": "git",
        "url": "https://github.com/FlavioKde/github-streak-stats-api.git"
    },
    "homepage": "https://github.com/FlavioKde/github-streak-stats-api#readme"

}